# MailAccess Environment Configuration

# Application Environment
# Can be 'development' or 'production'
MAILACCESS_ENV=development

# Database Connection
# Leave empty to use SQLite. Default: sqlite+aiosqlite:///./data/mailaccess.db
# To use Postgres, set this to your connection string. Example:
# DATABASE_URL=postgresql://user:password@db:5432/mailaccess
# DATABASE_URL=

# Backend Configuration
# The URL where the backend is accessible
BACKEND_URL=http://localhost:8000

# CORS Allowed Origins
# CORS_ORIGINS must be a JSON array - do not use a plain string
# Correct:   CORS_ORIGINS=["http://localhost:3000"]
# Wrong:     CORS_ORIGINS=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Application debug mode (true/false)
DEBUG=false
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Investigation Settings
# Maximum number of modules to run concurrently
MAX_CONCURRENT_MODULES=10
# Per-module timeout in seconds
MODULE_TIMEOUT_SECONDS=30
# MODULE_TIMEOUT_OVERRIDES must be a JSON object - do not use a plain string
# Correct:   MODULE_TIMEOUT_OVERRIDES={"whatsmyname": 200}
# Wrong:     MODULE_TIMEOUT_OVERRIDES=whatsmyname=200
MODULE_TIMEOUT_OVERRIDES={
  "whatsmyname": 200,
  "account_discovery": 120,
  "user_scanner": 180,
  "breach_deep": 90
}

# Whether to enable investigation history persistence
ENABLE_HISTORY=true

# Account discovery module: probes registration/reset endpoints across 57 platforms.
ENABLE_ACCOUNT_DISCOVERY=true  # Holehe 120+ platforms

# WhatsMyName module: username enumeration across 700+ platforms.
ENABLE_WHATSMYNAME=true        # 700+ platform sweep

# Native Maigret platform engine (2500+ platforms)
# Fetches platform database from Maigret GitHub (MIT)
# Cached locally for 24h. No Maigret install needed.
# Default true. Maigret is the new standard.
# 2500+ platforms checked by default.
# Set to false only to disable for speed.
# Adds ~35-90s to investigation time.
ENABLE_MAIGRET_PLATFORMS=true

# Maigret Wave 2 - slow/fragile platform sweep
# ~1000 additional regional and protected platforms.
# Requires ENABLE_MAIGRET_PLATFORMS=true.
# Adds ~90-150s additional.
ENABLE_MAIGRET_WAVE2=false

# Maximum platform domains checked for infrastructure clustering
DOMAIN_CLUSTER_CAP=20

# Per-platform demotion override
# Replace {PLATFORM} with uppercase platform name,
# non-alphanum stripped. Example below:
# MAIGRET_FORCE_GITHUBCOM=true

# Phase 6D.3 — opt-in community health sharing.
# Run `mailaccess platform-health --share` to post anonymized platform
# stats (hit rate, miss rate, inconclusive rate, avg latency, total probes,
# last_probed) to a public GitHub Gist. Strictly opt-in. Never runs
# automatically. Leave at false (or unset) — the --share flag is the only
# way this code path executes.
MAILACCESS_SHARE_HEALTH=false

# Enable domain infrastructure clustering
# Clusters platforms sharing registrar + /24 subnet
# Default: true. Cap controlled by DOMAIN_CLUSTER_CAP
enable_domain_cluster=true

# User-scanner: email registration probes across 205+ platforms (user-scanner package).
ENABLE_USER_SCANNER=true       # 205+ platform vectors

# Username pivot: re-checks WhatsMyName using usernames recovered from primary findings.
ENABLE_USERNAME_PIVOT=true     # username cross-check

# Permutation discovery: auto-generates email variations and probes each.
ENABLE_PERMUTATION_DISCOVERY=true # email variations

# Email discovery: searches public results for other emails tied to recovered names.
ENABLE_EMAIL_DISCOVERY=false   # opt-in: needs SERPAPI_KEY

# Press intelligence: opt-in search of press release archives for contact phones.
ENABLE_PRESS_INTEL=false       # opt-in: no API key required

# GHunt: deep Google account intelligence (GAIA ID, YouTube channel, Maps reviews, profile photo).
ENABLE_GHUNT=false             # opt-in: needs cookie setup
# Absolute path to the ghunt_creds.json file generated by `ghunt login`
GHUNT_CREDS_PATH=

# Phone intel: validate recovered phone numbers and probe WhatsApp/Telegram (post-primary).
ENABLE_PHONE_INTEL=true        # phone enrichment

# Messaging hints: best-effort Telegram username checks during primary gather.
ENABLE_MESSAGING_HINTS=true    # Telegram/WhatsApp hints

# PGP keyserver lookup: default-on public key UID name source, no API key required.
# MODULE: pgp_keyserver

# ORCID lookup: default-on public researcher identity source, no API key required.
# MODULE: orcid_lookup

# Hacker News lookup: default-on public profile/bio source, no API key required.
# MODULE: hackernews

# Deep breach mode: registration/reset probing against high-severity breached domains.
ENABLE_BREACH_DEEP=false       # opt-in: slow 90s probe
BREACH_DEEP_LIMIT=100
BREACH_DEEP_FULL=false

# Optional proxy for all requests (e.g. Tor or HTTP proxy)
# Example: socks5://127.0.0.1:9050  (Tor) or http://user:pass@proxy:port
PROXY_URL=
# Set to true to activate the proxy. Proxy is ignored when false.
PROXY_ENABLED=false

# Per-domain rate limiting
# Set to false to disable all rate limiting (not recommended in production)
RATE_LIMIT_ENABLED=true
# Default minimum delay between requests to the same domain (milliseconds)
REQUEST_DELAY_MS=1000
# Per-domain overrides as a JSON object (values in milliseconds)
# Example: RATE_LIMIT_OVERRIDES={"api.github.com": 500, "api.xposedornot.com": 1000, "haveibeenpwned.com": 1500}
RATE_LIMIT_OVERRIDES={}
# Legacy per-domain delays in seconds (JSON object): RATE_LIMIT_DELAYS={"haveibeenpwned.com": 1.5}
RATE_LIMIT_DELAYS={}

# Integrations (Webhooks)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
INTEGRATION_WEBHOOK_URL=
INTEGRATION_WEBHOOK_SECRET=

# API Keys (all optional, features will be disabled if key is missing)
# MAILACCESS_API_KEY restricts access to the REST API if set
MAILACCESS_API_KEY=

# Have I Been Pwned API Key for breach data (hibp module)
HIBP_API_KEY=

# XposedOrNot uses public breach endpoints and does not require an API key.

# LeakCheck uses public breach endpoints and does not require an API key.


# BreachDirectory API Key (RapidAPI — breachdirectory module)
# Free tier: https://rapidapi.com/rohan-patra/api/breachdirectory
BREACHDIRECTORY_API_KEY=

# SerpAPI Key for Google dork queries (google_dork and email_discovery modules)
SERPAPI_KEY=

# GitHub personal access token (optional)
# Required for github_commits commit search
# Without it, only user profile search runs
# Get at: github.com/settings/tokens
GITHUB_TOKEN=

# Shodan API Key for host intelligence (shodan module and domain_intel)
SHODAN_API_KEY=

# EmailRep API Key for email reputation checking (emailrep module, optional - raises rate limits)
EMAILREP_API_KEY=

# Hunter.io API Key for email deliverability checks (hunter_io module)
HUNTER_IO_API_KEY=

# Companies House API (UK company officer data)
# Free forever, no credit card required
# Get at: developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# Show Defender's Brief in CLI output (default: true)
# Set to false to suppress for all investigations
SHOW_DEFENDERS_BRIEF=true

# Common Crawl email harvesting (Phase A of 0.10.0 — domain harvest mode only).
# Master kill switch for the Common Crawl email module. The module is
# already opt-in via the domain harvest entry point; this is the global
# enable flag and lets you disable it entirely without touching the
# orchestrator config.
ENABLE_COMMONCRAWL_EMAIL=true
# Maximum number of Common Crawl URL Index records per harvest run.
# Each record is fetched and scanned for emails. Higher = more coverage,
# lower = faster. 100 is the default derived from research.
CC_MAX_RECORDS=100
# How many page fetches may run at once (WARC range fetch + direct GET).
# 10 is the default and keeps us well under S3 and target-site limits.
CC_FETCH_CONCURRENCY=10
# Per-fetch timeout (seconds) used for both WARC range and direct fetches.
CC_FETCH_TIMEOUT_SECONDS=8

# Search-engine dorking (Phase B1 of 0.10.0 — domain harvest mode only).
# Master kill switch for the email-search-dork module. The module itself
# is opt-in via domain harvest mode; this is the global enable flag.
ENABLE_EMAIL_SEARCH_DORK=true
# Maximum number of dork queries per engine (DDG + Bing) per harvest.
# 5 is the default — enough to cover all five core patterns while
# keeping total requests per harvest below CAPTCHA thresholds.
DORK_MAX_QUERIES_PER_ENGINE=5
# Lite mode runs only the first two patterns (broadest net) per engine.
# Faster, cheaper, lower coverage. Useful in time-constrained runs.
DORK_LITE_MODE=false
# Per-request delay between DDG queries (seconds). DDG throttles
# sustained heavy traffic — 5s is the safe default.
DORK_DDG_DELAY_SECONDS=5.0
# Per-request delay between Bing queries (seconds). Bing is more
# permissive than DDG but still throttles eventually — 4s default.
DORK_BING_DELAY_SECONDS=4.0

# Code + certificate-transparency email harvest (Phase B2 of 0.10.0).
# Master kill switch for the GitHub + crt.sh + certspotter module.
# The module is opt-in via domain harvest mode; this is the global
# enable flag.
ENABLE_CODE_AND_CERT_EMAIL=true
# Max GitHub code-search results to surface per harvest. Capped at
# 100 by GitHub itself; 30 is the default per research.
GITHUB_EMAIL_MAX_RESULTS=30
# After code search finds repositories mentioning the domain, GitHub
# commit-history is paged for up to this many repos. 10 keeps API
# usage well inside the unauthenticated 60/hour limit.
GITHUB_EMAIL_MAX_REPOS_CHECKED=10
# Per-repo commit page size when scanning for author emails. Capped
# at 100 by GitHub; 20 is the default.
GITHUB_EMAIL_MAX_COMMITS_PER_REPO=20
# Note: GITHUB_TOKEN (set elsewhere in this file or via
# `mailaccess keys set GITHUB_TOKEN your-token-here`) significantly
# improves rate limits for this module — 30 req/min authenticated
# vs. 10 req/min unauthenticated for the search endpoint.

# Employee / executive name discovery (Phase C1 of 0.10.0).
# Master kill switch for the multi-source name discovery module.
# It only runs in domain harvest mode and feeds Phase C2's pattern
# generator; normal email investigations are unaffected.
ENABLE_EMPLOYEE_NAME_DISCOVERY=true
# Maximum company pages (about/team/leadership) probed per harvest
# on the target's own domain. 5 is the default — covers the common
# paths without hitting rate limits on the target server.
EMPLOYEE_NAME_MAX_COMPANY_PAGES=5

# Email pattern generation + SMTP verification (Phase C2 of 0.10.0).
# Master kill switch — the module only runs in domain harvest mode
# and consumes Phase C1's name findings.
ENABLE_EMAIL_PATTERN_AND_VERIFY=true

# W5: Phase 0.10.0 final additions — three new structured-source
# modules for the harvest pipeline. Each queries a public registry
# / keyserver for emails associated with the target domain, no API
# key required. All three run concurrently with commoncrawl_email and
# code_and_cert_email via asyncio.gather.

# npm registry — package maintainer emails on registry.npmjs.org
# (searches for packages where the domain appears in package text;
#  also queries the domain keyword as a direct package-name guess).
ENABLE_NPM_EMAIL=true

# PyPI registry — package maintainer emails on pypi.org
# (XML-RPC search + JSON API fallback; also queries the domain
#  keyword as a direct package-name guess).
ENABLE_PYPI_EMAIL=true

# PGP keyserver domain-mode — UID-bearing public PGP keys filtered
# to the target domain string. queries keys.openpgp.org + the
# keyserver.ubuntu.com HKP search endpoint. Lower yield than the
# other two modules (1-5% realistic) but the highest-confidence
# possible source when it DOES return results — a PGP UID is a
# deliberate, user-verified assertion of identity.
ENABLE_PGP_DOMAIN_EMAIL=true

# ----- SMTP verification (Phase C2) -----
# CRITICAL:  Off by default.  Phase C2 can probe mail servers via
# RCPT TO to confirm mailbox existence.  This is a legitimate
# OSINT technique (no email is actually sent), but it carries
# operational risk — anti-spam systems can flag the source IP,
# and the technique is detectable.  Enable ONLY if you
# understand and accept the implications.
ENABLE_SMTP_VERIFICATION=false
# Per-request delay between SMTP probes (seconds).  Be conservative;
# aggressive probing triggers anti-spam blocks. 2.5s is the safe
# default (= max 24 probes/minute, well under the 30/min ceiling).
SMTP_PROBE_DELAY_SECONDS=2.5

# Note: smtp_max_probes_per_domain is HARD-CAPPED at 100 in the
# source — this default value (also 100) is the ceiling; setting
# it higher in your .env will have no effect.  Lower values are
# respected.

# Sender address used in the SMTP MAIL FROM envelope.  Must NOT be
# a real deliverable address; the literal value below is a
# non-routable .invalid domain per RFC 6761.  Changing this to
# anything real risks attributing probes back to your domain.
SMTP_SENDER_ADDRESS=probe@mailaccess.invalid
